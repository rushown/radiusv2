# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────
# SQLite file path (relative to backend root)
DATABASE_PATH=./data/radiuspay.db

# ─── Arc Blockchain ────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# USDC ERC-20 contract on Arc testnet (6 decimals)
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# Deployed LinkPay contract address (fill in after deployment)
LINKPAY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Stricter limit for claim-verify endpoint (brute-force protection)
VERIFY_RATE_LIMIT_WINDOW_MS=60000
VERIFY_RATE_LIMIT_MAX_REQUESTS=10

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
# NEVER log raw secrets or full claim IDs — use truncated/hashed values only

# ─── Security ──────────────────────────────────────────────────────────────
# Set to a long random string in production
API_SECRET=change_me_to_a_very_long_random_string_in_production

# ─── Frontend URL (for building claim links in responses) ──────────────────
FRONTEND_URL=http://localhost:5173
