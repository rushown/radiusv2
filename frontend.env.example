# ─── Frontend environment variables (.env.local) ─────────────────────────────
# Copy this to frontend/.env.local and fill in your values

# Backend API base URL
VITE_API_URL=http://localhost:4000

# Deployed LinkPay contract address (fill in after forge deploy)
VITE_LINKPAY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# USDC ERC-20 on Arc testnet (6 decimals) — usually don't change this
VITE_USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# Arc testnet chain ID
VITE_ARC_CHAIN_ID=5042002

# Arc testnet RPC URL
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# Block explorer (for tx links)
VITE_BLOCK_EXPLORER_URL=https://testnet.arcscan.app

# App base URL (used to build claim links)
VITE_APP_URL=http://localhost:5173
